ENVIRONMENT=production
SUPABASE_URL=https://REPLACE_BEFORE_RELEASE.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_BEFORE_RELEASE
COLLABORA_URL=https://REPLACE_BEFORE_RELEASE
# Space-separated application origins allowed to embed Collabora. Use explicit
# origins in deployed environments; omit locally to allow dynamic tunnel origins.
COLLABORA_FRAME_ANCESTORS=https://REPLACE_BEFORE_RELEASE
# Keep an entire trace attempt or discard it deterministically by trace UUID.
SOURCE_LINK_TRACE_SAMPLE_RATE=0.05
SOURCE_LINK_TRACE_ENABLED=true
WOPI_BASE_URL=https://REPLACE_BEFORE_RELEASE/agents/wopi/files
WOPI_SIGNING_KEY=REPLACE_BEFORE_RELEASE_WITH_32_RANDOM_BYTES
INTERNAL_SERVICE_KEY=REPLACE_BEFORE_RELEASE
# Optional Azure-first PDF layout provider. Set both or neither. Without these,
# digital PDFs use the safe embedded-text fallback; scanned PDFs are rejected.
DOCUMENTINTELLIGENCE_ENDPOINT=https://REPLACE_BEFORE_RELEASE.cognitiveservices.azure.com
DOCUMENTINTELLIGENCE_API_KEY=REPLACE_BEFORE_RELEASE
SHOPIFY_API_SECRET=REPLACE_BEFORE_RELEASE
SHOPIFY_TOKEN_ENCRYPTION_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
# SHOPIFY_TOKEN_ENCRYPTION_KEY_PREVIOUS=OPTIONAL_PREVIOUS_KEY_DURING_ROTATION
OFFLOAD_QUEUE_NAME=offload
OFFLOAD_LEASE_SECONDS=300
OFFLOAD_POLL_SECONDS=2
